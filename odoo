#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

DOCKER_COMPOSE="docker compose"

DB_NAME="${ODOO_DB:-odoo}"

DATA_DIR="$SCRIPT_DIR/data"
DB_DATA_DIR="$DATA_DIR/postgres"
ODOO_DATA_DIR="$DATA_DIR/odoo"

create_backup() {
    local timestamp backup_root
    timestamp="$(date +%Y%m%d_%H%M%S)"
    backup_root="$SCRIPT_DIR/backup/$timestamp"

    mkdir -p "$backup_root"

    echo "Creating backup at: $backup_root"
    
    if [ -d "$DB_DATA_DIR" ]; then
        echo "- Backing up PostgreSQL data..."
        tar czf "$backup_root/postgres_data.tgz" -C "$DATA_DIR" postgres
    fi

    if [ -d "$ODOO_DATA_DIR" ]; then
        echo "- Backing up Odoo filestore..."
        tar czf "$backup_root/odoo_data.tgz" -C "$DATA_DIR" odoo
    fi

    echo "Backup complete: $backup_root"
}

case "$1" in
    up)
                mkdir -p data/odoo data/postgres
                
                if [ "$(stat -c '%u' data/odoo)" != "101" ]; then
                    sudo chown -R 101:101 data/odoo 2>/dev/null || echo "Warning: You may need to run 'sudo chown -R 101:101 data/odoo' manually."
                fi
                if [ "$(stat -c '%u' data/postgres)" != "999" ]; then
                    sudo chown -R 999:999 data/postgres 2>/dev/null || echo "Warning: You may need to run 'sudo chown -R 999:999 data/postgres' manually."
                fi

                $DOCKER_COMPOSE up -d ;;
    down)       $DOCKER_COMPOSE down ;;
    stop)       $DOCKER_COMPOSE stop ;;
    restart)    $DOCKER_COMPOSE restart web ;;
    logs)       $DOCKER_COMPOSE logs -f web ;;
    ps)         $DOCKER_COMPOSE ps ;;
    build)      $DOCKER_COMPOSE build ;;
    shell)      $DOCKER_COMPOSE exec web odoo shell -d "$DB_NAME" ;;
    update|upgrade)
                if [ -z "$2" ]; then
                    echo "Usage: $0 update <module_name|all> [db_name]"
                    echo "       $0 upgrade <module_name|all> [db_name]"
                    echo "       ODOO_DB=<db_name> $0 upgrade <module_name|all>"
                    exit 1
                fi
                target_db="${3:-$DB_NAME}"
                if [ "$2" = "all" ]; then
                    echo "Updating all installed modules on DB: $target_db"
                else
                    echo "Updating module: $2 on DB: $target_db"
                fi
                $DOCKER_COMPOSE exec web odoo -u "$2" -d "$target_db" --stop-after-init
                $DOCKER_COMPOSE restart web
                ;;
    backup)
                echo "Stopping containers for consistent backup..."
                $DOCKER_COMPOSE down
                create_backup
                echo "Starting stack again..."
                $DOCKER_COMPOSE up -d
                ;;
    reset)
                if [ "$2" != "--yes" ]; then
                    echo "This will permanently delete all DB data and Odoo filestore."
                    echo "A backup will be created first in ./backup/<timestamp>/"
                    echo "Run with: $0 reset --yes"
                    exit 1
                fi

                echo "Stopping containers..."
                $DOCKER_COMPOSE down

                create_backup

                echo "Cleaning data directories..."
                rm -rf "$DB_DATA_DIR"/*
                rm -rf "$ODOO_DATA_DIR"/*

                $DOCKER_COMPOSE down -v

                echo "Starting fresh stack..."
                $DOCKER_COMPOSE up -d

                echo "Done. Open Odoo and create a new database."
                ;;
    *)
                echo "Usage: $0 {up|down|stop|restart|logs|ps|build|shell|update|upgrade|backup|reset}"
                echo "       $0 update <module_name|all> [db_name]"
                echo "       $0 upgrade <module_name|all> [db_name]"
                echo "       ODOO_DB=<db_name> $0 shell|update|upgrade ..."
                echo "       $0 backup"
                echo "       $0 reset --yes"
                exit 1
esac
